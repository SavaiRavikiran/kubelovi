apiVersion: v1
clusters:
  - cluster:
      certificate-authority-data: >-
        
      server: https://host.docker.internal:6443
      insecure-skip-tls-verify: true
    name: docker-desktop
  - cluster:
      certificate-authority: /Users/Ravikiran_Savai/.minikube/ca.crt
      extensions:
        - extension:
            last-update: Thu, 04 Dec 2025 10:54:45 IST
            provider: minikube.sigs.k8s.io
            version: v1.37.0
          name: cluster_info
      server: https://host.docker.internal:54535
      insecure-skip-tls-verify: true
    name: minikube
  - cluster:
      certificate-authority-data: >-
        
      server: https://host.docker.internal:6443
      insecure-skip-tls-verify: true
    name: rancher-desktop
contexts:
  - context:
      cluster: docker-desktop
      user: docker-desktop
    name: docker-desktop
  - context:
      cluster: minikube
      extensions:
        - extension:
            last-update: Thu, 04 Dec 2025 10:54:45 IST
            provider: minikube.sigs.k8s.io
            version: v1.37.0
          name: context_info
      namespace: default
      user: minikube
    name: minikube
  - context:
      cluster: rancher-desktop
      user: rancher-desktop
    name: rancher-desktop
current-context: docker-desktop
kind: Config
users:
  - name: docker-desktop
    user:
      client-certificate-data: >-
        
      client-key-data: >-
        
  - name: minikube
    user:
      client-certificate: /Users/Ravikiran_Savai/.minikube/profiles/minikube/client.crt
      client-key: /Users/Ravikiran_Savai/.minikube/profiles/minikube/client.key
  - name: rancher-desktop
